# ─── Telegram Bot ───────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ─── Telethon (for Colab pipeline) ──────────────────────────────────────────
API_ID=YOUR_TELEGRAM_API_ID_HERE
API_HASH=YOUR_TELEGRAM_API_HASH_HERE

# ─── Webhook ─────────────────────────────────────────────────────────────────
# Full URL where your Flask app is deployed (e.g. on PythonAnywhere)
WEBHOOK_URL=https://YOUR_USERNAME.pythonanywhere.com/webhook

# ─── Google Sheets / Service Account ─────────────────────────────────────────
# Path to your downloaded service account JSON file (keep it OUT of git)
SERVICE_ACCOUNT_FILE=service_account.json

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_FILE=bot.log
